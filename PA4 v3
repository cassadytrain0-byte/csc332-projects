import time
stepArr = []

#----------Recursive Algorithm-----------------
def recursiveAlg(n , steps, path, all_paths):
    if n == 0:
        all_paths.append(path.copy())
        return
    
    for step in steps:
        if step <= n:
            path.append(step)
            recursiveAlg(n - step, steps, path, all_paths)
            path.pop()

#----------Non-Recursive Algorithm---------------
def nonRecursiveAlg(n, steps):
    dp = [[] for _ in range(n + 1)]
    dp[0] = [[]]

    for i in range(1, n + 1):
        ways = []
        for step in steps:
            if i - step >= 0:
                for path in dp[i - step]:
                    ways.append(path + [step])
        dp[i] = ways
    
    return dp[n]

